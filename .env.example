# Copy this file to .env and fill in your API keys.
# .env is gitignored and must never be committed.

# --- LLM Provider API Keys ---
# Provide the key for whichever provider(s) you want to use.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
GOOGLE_API_KEY=...

# --- FoodScribe Defaults (optional) ---
# Set a default provider so you don't need --provider on every command.
FOODSCRIBE_LLM_PROVIDER=anthropic

# Set a default model (leave blank to use each provider's default).
# FOODSCRIBE_LLM_MODEL=claude-sonnet-4-6

# Path to the generated data/ folder (defaults to ./data).
# FOODSCRIBE_DATA_DIR=data
